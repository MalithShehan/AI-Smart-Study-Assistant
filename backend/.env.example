# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/ai_study_assistant
DB_MAX_POOL=10

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=AI Study Assistant <noreply@yourdomain.com>

# ── Client ────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── Firebase Cloud Messaging (FCM) ────────────────────────────────────────────
# Download your service account JSON from Firebase Console → Project Settings → Service Accounts
# Then set the absolute path to that file here.
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json

# ── File uploads ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
MAX_PDF_SIZE=20971520
UPLOAD_DIR=uploads

# ── Cloudinary (image / PDF cloud storage) ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Max completion tokens per task type
AI_MAX_TOKENS_SUMMARY=1024
AI_MAX_TOKENS_QUIZ=2048
AI_MAX_TOKENS_QA=512

# Sampling temperature per task (0 = deterministic, 1 = creative)
AI_TEMP_SUMMARY=0.3
AI_TEMP_QUIZ=0.7
AI_TEMP_QA=0.5

# Hard cap on input characters sent to the model (~4 chars ≈ 1 token)
AI_MAX_INPUT_CHARS=12000

# Request timeout in milliseconds
AI_TIMEOUT_MS=30000

# Number of retry attempts on transient errors (rate-limit / 5xx)
AI_RETRY_ATTEMPTS=3

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: error | warn | info | http | debug
LOG_LEVEL=debug

# ── Swagger ───────────────────────────────────────────────────────────────────
# Set to "true" to enable Swagger UI even in production
ENABLE_SWAGGER=true

# ── Admin ────────────────────────────────────────────────────────────────────
# Comma-separated emails that are automatically granted admin role on first register
ADMIN_SEED_EMAILS=admin@example.com
