# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins, or * to allow all (development only)
CORS_ORIGIN=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── AI Provider ───────────────────────────────────────────────────────────────
AI_API_KEY=your_api_key_here
AI_MODEL=gpt-3.5-turbo
